<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Training Hub</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #080810; color: #e2e0f0; font-family: 'Courier New', monospace; min-height: 100vh; }
  button { cursor: pointer; font-family: inherit; }
  input, select, textarea { font-family: inherit; }

  .header { background: linear-gradient(160deg,#0e0e1c,#160d2a); border-bottom: 1px solid #1c1c2e; padding: 18px 18px 0; }
  .header-top { display: flex; align-items: center; gap: 10px; margin-bottom: 2px; }
  .header-top .title { font-size: 16px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #fff; }
  .header-top .badge { margin-left: auto; font-size: 10px; color: #444460; }
  .header-sub { font-size: 10px; color: #444460; margin-bottom: 14px; }
  .nav { display: flex; }
  .nav-btn { flex: 1; padding: 9px 2px; background: none; border: none; border-bottom: 2px solid transparent; color: #444460; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 400; transition: all 0.2s; }
  .nav-btn.active { border-bottom-color: #7c5af7; color: #a07af0; font-weight: 700; }

  .content { padding: 16px; max-width: 500px; margin: 0 auto; }

  .plan-selector { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-bottom: 12px; }
  .plan-btn { padding: 10px 4px; border-radius: 10px; font-size: 12px; font-weight: 700; letter-spacing: 0.05em; transition: all 0.2s; }

  .card { background: #0d0d18; border: 1px solid #1c1c2e; border-radius: 12px; padding: 14px; margin-bottom: 12px; }

  .plan-hdr { border-radius: 10px; padding: 12px 14px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: flex-start; }
  .plan-hdr h2 { font-size: 18px; font-weight: 700; color: #fff; }
  .plan-hdr p { font-size: 11px; color: #888; margin-top: 2px; }
  .dur-badge { border-radius: 8px; padding: 6px 10px; text-align: center; flex-shrink: 0; margin-left: 10px; }
  .dur-badge .dl { font-size: 8px; letter-spacing: 0.1em; margin-bottom: 1px; }
  .dur-badge .dv { font-size: 11px; font-weight: 700; }

  .chips { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; margin-bottom: 12px; }
  .chip { font-size: 9px; font-weight: 700; padding: 2px 7px; border-radius: 20px; }

  .ex-item { background: #111120; border-radius: 10px; padding: 11px 12px; border-left: 3px solid #555; display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
  .ex-meta { display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
  .ex-num { font-size: 9px; color: #444460; font-weight: 700; background: #1a1a2e; border-radius: 4px; padding: 1px 5px; }
  .ex-tag { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; border-radius: 4px; padding: 1px 6px; }
  .ex-name { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 3px; }
  .ex-sets { font-size: 10px; color: #555570; }
  .ex-note { font-size: 10px; margin-top: 3px; font-style: italic; }
  .log-btn { border: none; color: #fff; border-radius: 7px; padding: 6px 10px; font-size: 10px; font-weight: 700; white-space: nowrap; flex-shrink: 0; }

  .protein-tip { background: #1a1a0a; border: 1px solid #333310; border-radius: 10px; padding: 10px 12px; font-size: 11px; color: #a0a060; margin-top: 12px; }
  .time-tip { background: #0a1a1a; border: 1px solid #103333; border-radius: 10px; padding: 10px 12px; font-size: 11px; color: #60a0a0; margin-top: 8px; }

  .form-row { display: flex; gap: 10px; margin-bottom: 14px; }
  .form-group { flex: 1; margin-bottom: 14px; }
  .form-group:last-child { margin-bottom: 0; }
  label { display: block; font-size: 9px; color: #555570; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 5px; font-weight: 700; }
  input, select, textarea { width: 100%; background: #0d0d18; border: 1px solid #252538; border-radius: 8px; color: #e2e0f0; padding: 9px 12px; font-size: 13px; outline: none; }
  textarea { resize: none; line-height: 1.5; }

  .sets-hdr { display: grid; grid-template-columns: 24px 1fr 1fr 1fr 24px; gap: 6px; margin-bottom: 6px; }
  .sets-hdr span { font-size: 9px; color: #444460; text-align: center; letter-spacing: 0.1em; }
  .set-row { display: grid; grid-template-columns: 24px 1fr 1fr 1fr 24px; gap: 6px; align-items: center; margin-bottom: 6px; }
  .set-num { font-size: 10px; color: #444460; text-align: center; }
  .set-inp { text-align: center !important; padding: 7px 4px !important; }
  .del-set { background: none; border: none; color: #ef4444; font-size: 14px; padding: 0; }
  .add-set { width: 100%; background: #111120; border: 1px dashed #252538; color: #7c5af7; padding: 7px; border-radius: 8px; font-size: 11px; margin-top: 2px; }
  .save-btn { width: 100%; border: none; color: #fff; padding: 13px; border-radius: 10px; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; transition: all 0.3s; margin-top: 14px; }
  .pre-filled { background: #111120; border-radius: 10px; padding: 10px 14px; font-size: 12px; font-weight: 700; margin-bottom: 14px; border-left: 3px solid #7c5af7; }

  .hist-item { background: #0d0d18; border: 1px solid #1c1c2e; border-radius: 12px; padding: 14px; margin-bottom: 10px; border-left: 3px solid #555; }
  .hist-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .ptag { display: inline-block; font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 4px; margin-bottom: 3px; }
  .hist-name { font-size: 12px; font-weight: 700; color: #fff; margin-bottom: 2px; }
  .hist-date { font-size: 10px; color: #444460; }
  .del-btn { background: none; border: none; color: #2a2a3e; font-size: 16px; padding: 0; }
  .set-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px; }
  .stag { background: #111120; border-radius: 6px; padding: 3px 8px; font-size: 11px; color: #b8b4d0; }
  .best { margin-top: 7px; font-size: 10px; color: #a07af0; }
  .enote { margin-top: 7px; font-size: 10px; color: #444460; font-style: italic; border-top: 1px solid #1c1c2e; padding-top: 7px; }

  .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 14px; }
  .stat-card { background: #0d0d18; border: 1px solid #1c1c2e; border-radius: 12px; padding: 14px; text-align: center; }
  .stat-icon { font-size: 20px; margin-bottom: 4px; }
  .stat-val { font-size: 24px; font-weight: 700; color: #fff; }
  .stat-lbl { font-size: 10px; color: #444460; letter-spacing: 0.05em; }

  .bar-row { margin-bottom: 8px; }
  .bar-top { display: flex; justify-content: space-between; margin-bottom: 3px; }
  .bar-bg { height: 4px; background: #111120; border-radius: 2px; }
  .bar-fill { height: 100%; border-radius: 2px; transition: width 0.5s; }

  .empty { text-align: center; color: #444460; padding: 40px 0; font-size: 13px; line-height: 1.8; }
</style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <span style="font-size:20px">⚡</span>
    <span class="title">Training Hub</span>
    <span class="badge">3-Split · 60-75 Min.</span>
  </div>
  <div class="header-sub" id="hsub">Plan V5 · 0 Einträge</div>
  <div class="nav">
    <button class="nav-btn active" onclick="showTab('plan')">Plan</button>
    <button class="nav-btn" onclick="showTab('log')">Loggen</button>
    <button class="nav-btn" onclick="showTab('history')">Verlauf</button>
    <button class="nav-btn" onclick="showTab('stats')">Stats</button>
  </div>
</div>

<div class="content">
  <div id="tab-plan"></div>
  <div id="tab-log" style="display:none"></div>
  <div id="tab-history" style="display:none"></div>
  <div id="tab-stats" style="display:none"></div>
</div>

<script>
// Plan V5 – Arme komplett raus (indirektes Volumen reicht), Bauch/Core in B (Stabilität für Grundübungen)
const PLAN = {
  A:{ name:"Workout A", sub:"Push + Rücken – Brust & Schulter Fokus", duration:"~60-65 Min.", color:"#ef4444",
    exercises:[
      {name:"Bankdrücken (Langhantel)", muscle:"Brust", sets:4, reps:"6-10", rest:"2 Min.", note:"⚡ Hauptübung – kontrolliert, volle ROM"},
      {name:"Schrägbank Brustpresse (Maschine)", muscle:"Brust", sets:3, reps:"10-12", rest:"75 Sek.", note:"Obere Brust"},
      {name:"Schulterdrücken (Maschine)", muscle:"Schultern", sets:3, reps:"8-12", rest:"75 Sek.", note:""},
      {name:"Kabelrudern (sitzend)", muscle:"Rücken", sets:3, reps:"10-12", rest:"75 Sek.", note:"Rücken-Gegenzug"},
      {name:"Seitheben (Hantel oder Maschine)", muscle:"Schultern", sets:3, reps:"12-15", rest:"45 Sek.", note:""},
    ]},
  B:{ name:"Workout B", sub:"Pull + Beine – Rücken, Schulter & Core", duration:"~60-65 Min.", color:"#22c55e",
    exercises:[
      {name:"Rumänisches Kreuzheben", muscle:"Beine", sets:3, reps:"8-10", rest:"90 Sek.", note:"⚡ Hintere Kette, kontrolliert"},
      {name:"Latzug (breit)", muscle:"Rücken", sets:4, reps:"8-12", rest:"75 Sek.", note:""},
      {name:"Beinbeuger (Maschine)", muscle:"Beine", sets:3, reps:"12-15", rest:"60 Sek.", note:"Hamstrings isoliert"},
      {name:"Face Pulls (Kabel)", muscle:"Schultern", sets:3, reps:"12-15", rest:"45 Sek.", note:"⚡ Schultergesundheit – nie weglassen"},
      {name:"Butterfly/Pec-Deck (Maschine)", muscle:"Brust", sets:3, reps:"10-15", rest:"60 Sek.", note:"Extra Brust-Volumen"},
      {name:"Cable Crunch", muscle:"Bauch", sets:3, reps:"12-15", rest:"45 Sek.", note:"⚡ Rumpfstabilität für Kreuzheben & Bankdrücken"},
    ]},
  C:{ name:"Workout C", sub:"Push/Pull Mix – Volumen & Kraft", duration:"~60-65 Min.", color:"#a855f7",
    exercises:[
      {name:"Dips (gewichtet oder Maschine)", muscle:"Brust", sets:4, reps:"8-12", rest:"75 Sek.", note:"⚡ Brust + Trizeps"},
      {name:"Rudern T-Bar (oder Maschine)", muscle:"Rücken", sets:4, reps:"8-12", rest:"75 Sek.", note:""},
      {name:"Brustpresse (Maschine, horizontal)", muscle:"Brust", sets:3, reps:"10-15", rest:"60 Sek.", note:"Brust finishen"},
      {name:"Latzug (eng, supiniert)", muscle:"Rücken", sets:3, reps:"10-12", rest:"75 Sek.", note:""},
      {name:"Fliegende (Kabel)", muscle:"Brust", sets:2, reps:"12-15", rest:"45 Sek.", note:"Dehnung & Kontraktion"},
    ]},
  Cardio:{ name:"Cardio", sub:"Zone 2 & Tempo – an freien Tagen", duration:"60-90 Min.", color:"#06b6d4",
    exercises:[
      {name:"Zone 2 Laufen", muscle:"Cardio", sets:1, reps:"60 Min.", rest:"–", note:"⚡ 60-70% max. HF · nüchtern ideal"},
      {name:"Zone 2 Laufen (lang)", muscle:"Cardio", sets:1, reps:"75-90 Min.", rest:"–", note:"Ausdaueraufbau"},
      {name:"Tempo-Training", muscle:"Cardio", sets:1, reps:"30-45 Min.", rest:"–", note:"80-90% max. HF · nach Ruhetag"},
    ]}
};

const MC = {Brust:"#ef4444",Schultern:"#f97316",Rücken:"#22c55e",Beine:"#3b82f6",Bauch:"#eab308",Cardio:"#06b6d4"};
const KEYS = ["A","B","C","Cardio"];

let tab = "plan";
let ap = "A";
let entries = JSON.parse(localStorage.getItem("wt-log") || "[]");
let lf = { date:td(), type:"Kraft", exercise:"", planTag:"", note:"", sets:[{w:"",r:"",rpe:""}] };
let hf = "Alle", sf = "Alle";

function td(){ return new Date().toISOString().split("T")[0]; }
function fd(iso){ return new Date(iso).toLocaleDateString("de-DE",{day:"2-digit",month:"2-digit",year:"numeric"}); }
function h(c,a){ return c+Math.round(a*255).toString(16).padStart(2,"0"); }
function esc(s){ return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }

function saveEntries(){
  localStorage.setItem("wt-log", JSON.stringify(entries));
  document.getElementById("hsub").textContent = `Plan V5 · ${entries.length} Einträge`;
}

function showTab(t){
  tab = t;
  ["plan","log","history","stats"].forEach(x=>{
    document.getElementById("tab-"+x).style.display = x===t?"":"none";
  });
  document.querySelectorAll(".nav-btn").forEach((b,i)=>{
    b.classList.toggle("active", ["plan","log","history","stats"][i]===t);
  });
  render();
}

function render(){
  if(tab==="plan") rPlan();
  if(tab==="log") rLog();
  if(tab==="history") rHist();
  if(tab==="stats") rStats();
}

function rPlan(){
  const p = PLAN[ap];
  const grps = {};
  p.exercises.forEach(e=>{ grps[e.muscle]=(grps[e.muscle]||0)+1; });
  const summary = Object.entries(grps).sort((a,b)=>b[1]-a[1]);

  let o = `<div class="plan-selector">`;
  KEYS.forEach(k=>{
    const act = k===ap;
    o += `<button class="plan-btn" onclick="ap='${k}';rPlan()"
      style="background:${act?PLAN[k].color:'#0d0d18'};color:${act?'#fff':'#555570'};border:${act?'none':'1px solid #1c1c2e'}">${k}</button>`;
  });
  o += `</div><div class="card">`;
  o += `<div class="plan-hdr" style="background:linear-gradient(135deg,${h(p.color,0.13)},${h(p.color,0.03)});border:1px solid ${h(p.color,0.2)}">
    <div><h2>${p.name}</h2><p>${p.sub}</p></div>
    <div class="dur-badge" style="background:${h(p.color,0.2)}">
      <div class="dl" style="color:${p.color}">DAUER</div>
      <div class="dv" style="color:${p.color}">${p.duration}</div>
    </div>
  </div>`;
  o += `<div class="chips">`;
  summary.forEach(([m,c])=>{
    const col=MC[m]||"#888";
    o+=`<span class="chip" style="background:${h(col,0.13)};color:${col};border:1px solid ${h(col,0.27)}">${m} ×${c}</span>`;
  });
  o += `</div>`;
  p.exercises.forEach((ex,i)=>{
    const c=MC[ex.muscle]||"#555";
    o+=`<div class="ex-item" style="border-left-color:${c}">
      <div style="flex:1">
        <div class="ex-meta">
          <span class="ex-num">${i+1}</span>
          <span class="ex-tag" style="color:${c};background:${h(c,0.09)}">${ex.muscle.toUpperCase()}</span>
        </div>
        <div class="ex-name">${esc(ex.name)}</div>
        <div class="ex-sets">${ex.sets}× ${ex.reps} · ⏱ ${ex.rest}</div>
        ${ex.note?`<div class="ex-note" style="color:${ex.note.startsWith('⚡')?c:'#555570'}">${ex.note}</div>`:""}
      </div>
      <button class="log-btn" onclick="startLog(${JSON.stringify(ex.name)},${JSON.stringify(ap)})"
        style="background:linear-gradient(135deg,${p.color}cc,${p.color})">+ Log</button>
    </div>`;
  });
  o+=`<div class="protein-tip">💪 Ziel: 156g Protein/Tag · Besonders wichtig an Cardio-Tagen</div>`;
  if(ap!=="Cardio") o+=`<div class="time-tip">⏱ Bei 3x/Woche: A→B→C→A… · Bei 4x/Woche flexibel weiterrotieren, Hauptsache die Reihenfolge bleibt A→B→C</div>`;
  o+=`</div>`;
  document.getElementById("tab-plan").innerHTML = o;
}

function startLog(name, planKey){
  lf.exercise=name; lf.planTag=planKey;
  lf.type=planKey==="Cardio"?"Cardio":"Kraft";
  lf.sets=[{w:"",r:"",rpe:""}]; lf.note="";
  showTab("log");
}

function rLog(){
  const p=lf.planTag?PLAN[lf.planTag]:null;
  const allEx=Object.values(PLAN).flatMap(pl=>pl.exercises.map(e=>e.name));
  let o="";
  if(lf.exercise&&p){
    o+=`<div class="pre-filled" style="border-left-color:${p.color};color:${p.color}">⚡ Workout ${lf.planTag} · ${esc(lf.exercise)}</div>`;
  }
  o+=`<div class="form-row">
    <div class="form-group" style="margin-bottom:0">
      <label>Datum</label>
      <input type="date" value="${lf.date}" onchange="lf.date=this.value">
    </div>
    <div class="form-group" style="margin-bottom:0">
      <label>Typ</label>
      <select onchange="lf.type=this.value">
        <option ${lf.type==="Kraft"?"selected":""}>Kraft</option>
        <option ${lf.type==="Cardio"?"selected":""}>Cardio</option>
        <option ${lf.type==="Mobility"?"selected":""}>Mobility</option>
      </select>
    </div>
  </div>`;
  o+=`<div class="form-group" style="margin-top:14px">
    <label>Übung</label>
    <input list="exl" value="${esc(lf.exercise)}" oninput="lf.exercise=this.value" placeholder="Aus Plan oder frei eingeben…">
    <datalist id="exl">${allEx.map(n=>`<option value="${esc(n)}">`).join("")}</datalist>
  </div>`;
  o+=`<div class="form-group"><label>Sätze</label>
    <div class="sets-hdr"><span></span><span>KG</span><span>WDH</span><span>RPE</span><span></span></div>`;
  lf.sets.forEach((s,i)=>{
    o+=`<div class="set-row">
      <span class="set-num">${i+1}</span>
      <input type="number" class="set-inp" placeholder="60" value="${s.w}" oninput="lf.sets[${i}].w=this.value">
      <input type="number" class="set-inp" placeholder="8" value="${s.r}" oninput="lf.sets[${i}].r=this.value">
      <input type="number" class="set-inp" placeholder="7" value="${s.rpe}" oninput="lf.sets[${i}].rpe=this.value">
      <button class="del-set" onclick="delSet(${i})" ${lf.sets.length===1?"disabled style='opacity:0.3'":""}>×</button>
    </div>`;
  });
  o+=`<button class="add-set" onclick="addSet()">+ Satz hinzufügen</button></div>`;
  o+=`<div class="form-group"><label>Notiz</label>
    <textarea rows="2" placeholder="Wie lief es?" oninput="lf.note=this.value">${esc(lf.note)}</textarea>
  </div>`;
  o+=`<button class="save-btn" id="sbtn" style="background:linear-gradient(135deg,#7c3aed,#a855f7)" onclick="saveEntry()">Eintrag speichern</button>`;
  document.getElementById("tab-log").innerHTML=o;
}

function addSet(){ lf.sets.push({w:"",r:"",rpe:""}); rLog(); }
function delSet(i){ if(lf.sets.length>1){ lf.sets.splice(i,1); rLog(); } }

function saveEntry(){
  if(!lf.exercise) return;
  let muscle="–";
  for(const p of Object.values(PLAN)){
    const ex=p.exercises.find(e=>e.name===lf.exercise);
    if(ex){ muscle=ex.muscle; break; }
  }
  entries.unshift({
    id:Date.now(), date:lf.date, type:lf.type,
    exercise:lf.exercise, muscle, planTag:lf.planTag, note:lf.note,
    sets:lf.sets.filter(s=>s.w||s.r).map(s=>({weight:s.w,reps:s.r,rpe:s.rpe}))
  });
  saveEntries();
  const btn=document.getElementById("sbtn");
  btn.textContent="✓ Gespeichert!";
  btn.style.background="linear-gradient(135deg,#22c55e,#16a34a)";
  setTimeout(()=>{ lf.sets=[{w:"",r:"",rpe:""}]; lf.note=""; rLog(); },1500);
}

function rHist(){
  const allEx=["Alle",...new Set(entries.map(e=>e.exercise))];
  let o=`<div class="form-group"><label>Filtern</label>
    <select onchange="hf=this.value;rHist()">
      ${allEx.map(n=>`<option ${n===hf?"selected":""}>${esc(n)}</option>`).join("")}
    </select></div>`;
  const filtered=entries.filter(e=>hf==="Alle"||e.exercise===hf);
  if(!filtered.length){
    o+=`<div class="empty">Noch keine Einträge.<br>Trag dein erstes Workout ein! 💪</div>`;
  } else {
    filtered.forEach(e=>{
      const pc=e.planTag&&PLAN[e.planTag]?PLAN[e.planTag].color:(MC[e.muscle]||"#555");
      const best=bset(e);
      o+=`<div class="hist-item" style="border-left-color:${pc}">
        <div class="hist-top">
          <div>
            ${e.planTag?`<span class="ptag" style="background:${h(pc,0.13)};color:${pc}">Workout ${e.planTag}</span><br>`:""}
            <div class="hist-name">${esc(e.exercise)}</div>
            <div class="hist-date">${fd(e.date)} · ${e.type}</div>
          </div>
          <button class="del-btn" onclick="delEntry(${e.id})">×</button>
        </div>`;
      if(e.sets&&e.sets.length){
        o+=`<div class="set-tags">`;
        e.sets.forEach(s=>{
          o+=`<span class="stag">${s.weight?s.weight+"kg":"–"} × ${s.reps||"–"}${s.rpe?` <span style="color:#444460">@${s.rpe}</span>`:""}</span>`;
        });
        o+=`</div>`;
      }
      if(best) o+=`<div class="best">⚡ Best: ${best.weight}kg × ${best.reps} Wdh${best.rpe?` @ RPE ${best.rpe}`:""}</div>`;
      if(e.note) o+=`<div class="enote">${esc(e.note)}</div>`;
      o+=`</div>`;
    });
  }
  document.getElementById("tab-history").innerHTML=o;
}

function delEntry(id){ entries=entries.filter(e=>e.id!==id); saveEntries(); rHist(); }
function bset(e){
  if(!e.sets||!e.sets.length) return null;
  return e.sets.reduce((b,s)=>(parseFloat(s.weight)||0)>(parseFloat(b.weight)||0)?s:b,e.sets[0]);
}

function rStats(){
  const allEx=["Alle",...new Set(entries.map(e=>e.exercise))];
  const mc={};
  entries.forEach(e=>{ mc[e.muscle]=(mc[e.muscle]||0)+1; });
  const maxM=Math.max(...Object.values(mc),1);
  const total=Math.max(entries.length,1);
  let o=`<div class="stats-grid">`;
  [["Einheiten",entries.length,"📋"],["Übungen",new Set(entries.map(e=>e.exercise)).size,"🏋️"],
   ["Krafttage",entries.filter(e=>e.type==="Kraft").length,"💪"],["Cardiotage",entries.filter(e=>e.type==="Cardio").length,"🏃"]]
  .forEach(([l,v,ic])=>{
    o+=`<div class="stat-card"><div class="stat-icon">${ic}</div><div class="stat-val">${v}</div><div class="stat-lbl">${l}</div></div>`;
  });
  o+=`</div><div class="card"><div style="font-size:12px;font-weight:700;color:#fff;margin-bottom:12px">Einheiten pro Workout</div>`;
  KEYS.forEach(k=>{
    const cnt=entries.filter(e=>e.planTag===k).length;
    o+=`<div class="bar-row">
      <div class="bar-top"><span style="font-size:11px;color:${PLAN[k].color}">${PLAN[k].name}</span><span style="font-size:11px;color:#444460">${cnt}×</span></div>
      <div class="bar-bg"><div class="bar-fill" style="width:${(cnt/total)*100}%;background:${PLAN[k].color}"></div></div>
    </div>`;
  });
  o+=`</div><div class="form-group"><label>Übung analysieren</label>
    <select onchange="sf=this.value;rStats()">
      ${allEx.map(n=>`<option ${n===sf?"selected":""}>${esc(n)}</option>`).join("")}
    </select></div>`;
  if(sf!=="Alle"){
    const hist=entries.filter(e=>e.exercise===sf);
    if(hist.length){
      const maxW=Math.max(...hist.flatMap(e=>(e.sets||[]).map(s=>parseFloat(s.weight)||0)),1);
      o+=`<div class="card"><div style="font-size:12px;font-weight:700;color:#fff;margin-bottom:12px">${esc(sf)} – Verlauf</div>`;
      hist.slice(0,10).forEach(e=>{
        const best=bset(e); const pct=best?((parseFloat(best.weight)||0)/maxW)*100:0;
        o+=`<div class="bar-row">
          <div class="bar-top"><span style="font-size:10px;color:#444460">${fd(e.date)}</span>
          ${best?`<span style="font-size:11px;color:#a07af0;font-weight:700">${best.weight}kg × ${best.reps}</span>`:""}</div>
          <div class="bar-bg"><div class="bar-fill" style="width:${pct}%;background:linear-gradient(90deg,#7c3aed,#a855f7)"></div></div>
        </div>`;
      });
      o+=`</div>`;
    }
  }
  if(entries.length){
    o+=`<div class="card"><div style="font-size:12px;font-weight:700;color:#fff;margin-bottom:12px">Muskelgruppen</div>`;
    Object.entries(mc).sort((a,b)=>b[1]-a[1]).forEach(([m,cnt])=>{
      const c=MC[m]||"#888";
      o+=`<div class="bar-row">
        <div class="bar-top"><span style="font-size:11px;color:${c}">${m}</span><span style="font-size:11px;color:#444460">${cnt}×</span></div>
        <div class="bar-bg"><div class="bar-fill" style="width:${(cnt/maxM)*100}%;background:${c}"></div></div>
      </div>`;
    });
    o+=`</div>`;
  }
  document.getElementById("tab-stats").innerHTML=o;
}

lf.date=td();
saveEntries();
render();
</script>
</body>
</html>
